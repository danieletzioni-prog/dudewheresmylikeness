---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Override the default OG image (path or absolute URL). */
  ogImage?: string;
  /** OG type — "website" for the landing page, "article" for state pages, etc. */
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'A public watchtower for AI likeness rights: what the laws are, how fast the world is moving, and what just happened.',
  ogImage = '/images/og-image.jpg',
  ogType = 'website',
} = Astro.props;

// Resolve absolute URLs against the site URL set in astro.config.mjs.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = new URL(ogImage, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* Open Graph (LinkedIn, Facebook, iMessage, Slack, WhatsApp, etc.) */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="dudewheresmylikeness.ai" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta property="og:image:alt" content="dudewheresmylikeness.ai — AI-generated riff on the Dude, Where's My Car? movie poster, with phones showing fake AI-Kutcher Instagram ads" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <div class="max-w-6xl mx-auto w-full px-5 pt-3 pb-1">
      <p class="text-xs md:text-sm text-[var(--color-ink)]">
        Built by <a
          href="https://www.linkedin.com/in/daniel-etzioni/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-ink)] underline decoration-[var(--color-muted)] decoration-1 underline-offset-[3px] hover:decoration-[var(--color-ink)] hover:decoration-2"
        >Daniel Etzioni</a>
      </p>
    </div>
    <main class="flex-1 w-full">
      <slot />
    </main>
    <Footer />

    {/* Shared init for all <SubscribeForm> instances on the page. */}
    <script is:inline>
      (() => {
        const init = () => {
          if (window.__buttondownInit) return;
          window.__buttondownInit = true;

          const forms = document.querySelectorAll('form[data-buttondown-form]');
          forms.forEach((form) => {
            const button = form.querySelector('button[type="submit"]');
            const input = form.querySelector('input[name="email"]');
            const status = form.querySelector('[data-form-status]');
            if (!button || !input || !status) return;

            const setStatus = (text, kind) => {
              status.classList.remove('hidden');
              status.textContent = text;
              status.dataset.kind = kind;
              const cls = {
                ok: 'text-[var(--color-blue)]',
                err: 'text-[var(--color-red)]',
                info: 'text-[var(--color-muted)]',
              }[kind] || '';
              ['text-[var(--color-blue)]', 'text-[var(--color-red)]', 'text-[var(--color-muted)]', 'text-[var(--color-cream)]/80'].forEach(
                (c) => status.classList.remove(c),
              );
              if (cls) status.classList.add(cls);
            };

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              const email = (input.value || '').trim();
              if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                setStatus('Please enter a valid email.', 'err');
                input.focus();
                return;
              }

              const original = button.dataset.defaultLabel || button.textContent || 'Subscribe';
              button.disabled = true;
              button.textContent = '…';
              setStatus('', 'info');
              status.classList.add('hidden');

              const tag = form.dataset.tag;
              const tags = tag ? [tag] : [];

              try {
                const res = await fetch('/api/subscribe', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json' },
                  body: JSON.stringify({ email, tags }),
                });
                const data = await res.json().catch(() => ({}));

                if (data && data.ok) {
                  // Inline success: replace form contents with confirmation.
                  form.innerHTML =
                    '<p class="text-sm font-extrabold uppercase tracking-[0.12em] text-[var(--color-blue)]">' +
                    '✓ Subscribed. Check your inbox.' +
                    (data.simulated ? ' <span class="text-[var(--color-muted)] normal-case font-normal tracking-normal">(preview mode — Buttondown key not yet configured.)</span>' : '') +
                    '</p>';
                  return;
                }

                setStatus(
                  (data && data.error) || 'Subscription failed. Please try again later.',
                  'err',
                );
              } catch (err) {
                setStatus('Network error. Please try again.', 'err');
              } finally {
                button.disabled = false;
                button.textContent = original;
              }
            });
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
