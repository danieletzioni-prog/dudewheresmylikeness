---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KutcherWidget from '../components/KutcherWidget.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'A public watchtower for AI likeness rights: what the laws are, how fast the world is moving, and what just happened.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <div class="max-w-6xl mx-auto w-full px-5 pt-3 pb-1">
      <p class="text-xs md:text-sm text-[var(--color-ink)]">
        Built by <a
          href="https://www.linkedin.com/in/daniel-etzioni/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-ink)] no-underline hover:underline decoration-[var(--color-ink)] underline-offset-2"
        >Daniel Etzioni</a>
      </p>
    </div>
    <main class="flex-1 w-full">
      <slot />
    </main>
    <Footer />
    <KutcherWidget />
  </body>
</html>
