---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const states = await getCollection('states');
  return states.map((s) => ({
    params: { abbr: s.data.abbr.toLowerCase() },
    props: { state: s.data },
  }));
}

const { state } = Astro.props;

const categoryMeta: Record<number, { label: string; bg: string; fg: string }> = {
  1: { label: 'Comprehensive AI-era statute', bg: 'bg-[var(--color-cat-1)]', fg: 'text-white' },
  2: { label: 'Strong publicity statute, AI coverage developing', bg: 'bg-[var(--color-cat-2)]', fg: 'text-white' },
  3: { label: 'Traditional publicity statute, no AI-specific overlay', bg: 'bg-[var(--color-cat-3)]', fg: 'text-[var(--color-ink)]' },
  4: { label: 'Common law or unverified', bg: 'bg-[var(--color-cat-4)]', fg: 'text-[var(--color-ink)]' },
};
const cat = categoryMeta[state.category];

// Markdown link [text](url) → <a> + minimal **bold** and *italic* support.
function renderInline(text: string): string {
  if (!text) return '';
  const escape = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  // Tokenize so we don't double-escape inside link text.
  let out = '';
  let i = 0;
  const linkRe = /\[([^\]]+)\]\(([^)]+)\)/g;
  let m: RegExpExecArray | null;
  while ((m = linkRe.exec(text)) !== null) {
    out += escape(text.slice(i, m.index));
    const url = m[2].startsWith('http') ? m[2] : `https://${m[2]}`;
    out += `<a href="${escape(url)}" target="_blank" rel="noopener noreferrer" class="underline decoration-[var(--color-orange)] hover:text-[var(--color-orange-deep)]">${escape(m[1])}</a>`;
    i = m.index + m[0].length;
  }
  out += escape(text.slice(i));
  // **bold** and *italic* (very narrow rules — won't conflict with stars in case names).
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  out = out.replace(/(^|[\s(])\*([^*]+)\*([\s.,;:)?!]|$)/g, '$1<em>$2</em>$3');
  return out;
}

const correctionSubject = encodeURIComponent(`Correction: ${state.name}`);
---
<Layout title={`${state.name} — AI likeness rights | dudewheresmylikeness.com`} description={state.tooltip}>
  <article class="max-w-3xl mx-auto px-5 py-10 md:py-14">
    <a href="/#map" class="no-underline text-xs font-extrabold uppercase tracking-[0.2em] text-[var(--color-blue)] hover:text-[var(--color-orange-deep)]">&larr; Back to the map</a>

    <header class="mt-6 pb-8 border-b-2 border-[var(--color-blue)]/20">
      <span class={`inline-block px-3 py-1 rounded-full ${cat.bg} ${cat.fg} text-[10px] font-extrabold uppercase tracking-[0.18em] shadow-[0_2px_0_0_rgba(0,0,0,0.15)]`}>
        Cat&nbsp;{state.category} — {cat.label}
      </span>
      <h1 class="mt-4 display text-5xl md:text-6xl text-[var(--color-ink)]">{state.name}</h1>
      {state.tooltip && (
        <p class="mt-3 text-[var(--color-ink-soft)] text-base md:text-lg leading-snug max-w-2xl">{state.tooltip.replace(/^[^—]+—\s*Cat \d:\s*/, '')}</p>
      )}
    </header>

    <section class="mt-10">
      <h2 class="display text-2xl text-[var(--color-blue)]">The 60-second answer</h2>
      <dl class="mt-5 grid gap-6">
        <div class="poster-card p-5 md:p-6">
          <dt class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[var(--color-orange-deep)]">Are you protected during life?</dt>
          <dd class="mt-2 text-[var(--color-ink)] leading-relaxed" set:html={renderInline(state.rightOfPublicity)}></dd>
        </div>
        <div class="poster-card p-5 md:p-6">
          <dt class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[var(--color-orange-deep)]">Are you protected after death?</dt>
          <dd class="mt-2 text-[var(--color-ink)] leading-relaxed" set:html={renderInline(state.postMortem)}></dd>
        </div>
        <div class="poster-card p-5 md:p-6">
          <dt class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[var(--color-orange-deep)]">Is AI specifically called out?</dt>
          <dd class="mt-2 text-[var(--color-ink)] leading-relaxed" set:html={renderInline(state.aiCoverage)}></dd>
        </div>
        {state.remedy && (
          <div class="poster-card p-5 md:p-6">
            <dt class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[var(--color-orange-deep)]">What do you actually do if it happens?</dt>
            <dd class="mt-2 text-[var(--color-ink)] leading-relaxed" set:html={renderInline(state.remedy)}></dd>
          </div>
        )}
      </dl>
    </section>

    {state.whatsInteresting && (
      <section class="mt-12">
        <h2 class="display text-2xl text-[var(--color-blue)]">What's interesting about this state</h2>
        <p class="mt-4 text-[var(--color-ink)] leading-relaxed text-base md:text-lg" set:html={renderInline(state.whatsInteresting)}></p>
      </section>
    )}

    {state.primarySources && state.primarySources.length > 0 && (
      <section class="mt-12">
        <h2 class="display text-2xl text-[var(--color-blue)]">Primary sources</h2>
        <ul class="mt-4 list-disc pl-5 space-y-2 text-[var(--color-ink-soft)]">
          {state.primarySources.map((src: string) => (
            <li set:html={renderInline(src)}></li>
          ))}
        </ul>
      </section>
    )}

    <footer class="mt-14 pt-6 border-t-2 border-[var(--color-blue)]/20 flex flex-col md:flex-row md:items-baseline md:justify-between gap-3 text-xs">
      {state.lastVerified && (
        <p class="text-[var(--color-muted)] uppercase tracking-[0.15em] font-bold">
          Last verified: <span class="text-[var(--color-ink)]">{state.lastVerified}</span>
        </p>
      )}
      <p class="text-[var(--color-muted)]">
        Spotted an error?{' '}
        <a
          href={`mailto:hello@dudewheresmylikeness.com?subject=${correctionSubject}`}
          class="font-extrabold uppercase tracking-[0.12em] text-[var(--color-blue)] hover:text-[var(--color-orange-deep)] no-underline"
        >
          Report a correction &rarr;
        </a>
      </p>
    </footer>
  </article>
</Layout>
