---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={`${post.data.title} — The Feed`} description={post.data.excerpt}>
  <article class="max-w-2xl mx-auto px-6 pt-12 pb-24">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">
      <a href="/feed" class="no-underline">&larr; The Feed</a>
    </p>
    <h1 class="mt-6 font-serif text-4xl md:text-5xl tracking-tight leading-[1.1]">
      {post.data.title}
    </h1>
    <p class="mt-4 text-sm text-[var(--color-muted)]">
      {fmt(post.data.date)} &middot;
      Source: <a href={post.data.sourceUrl} target="_blank" rel="noopener noreferrer">{post.data.sourceName}</a>
    </p>
    {post.data.tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2 text-[10px] uppercase tracking-wider text-[var(--color-muted)]">
        {post.data.tags.map((tag: string) => (
          <li class="border border-[var(--color-rule)] px-2 py-0.5">{tag}</li>
        ))}
      </ul>
    )}
    <div class="prose mt-10 font-serif text-lg leading-relaxed">
      <Content />
    </div>
  </article>
</Layout>
