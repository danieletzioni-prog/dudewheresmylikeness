---
import Layout from '../../layouts/Layout.astro';
import aggregated from '../../data/aggregated-feed.json';
import featured from '../../data/featured-stories.json';

const featuredItems = (featured.items ?? []).filter((x: any) => x.featured);
const featuredIds = new Set(featuredItems.map((x: any) => x.id));
const items = (aggregated.items ?? []).filter((it: any) => !featuredIds.has(it.id));

const fmtDate = (iso?: string | null) => {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const allTags = ['legislation', 'platform-policy', 'litigation', 'industry-news'] as const;
const TAG_LABEL: Record<string, string> = {
  'legislation': 'Legislation',
  'platform-policy': 'Platform policy',
  'litigation': 'Litigation',
  'industry-news': 'Industry news',
};

const generatedAt = aggregated.generatedAt
  ? new Date(aggregated.generatedAt).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit', timeZoneName: 'short' })
  : null;
---
<Layout title="The Feed — dudewheresmylikeness.com">
  <section class="max-w-4xl mx-auto px-5 pt-12 pb-6">
    <span class="poster-bar">The Feed</span>
    <h1 class="mt-5 display text-[clamp(2.5rem,6vw,4.5rem)]">
      <span class="text-[var(--color-orange)]">WTF</span> <span class="text-[var(--color-blue)]">is happening</span>
    </h1>
    <p class="mt-4 text-[var(--color-ink-soft)] max-w-2xl">
      Aggregated news on AI likeness rights, deepfakes, right-of-publicity legislation, and
      platform policy. Auto-refreshed daily; featured stories curated by hand.
    </p>
    {generatedAt && (
      <p class="mt-2 text-xs text-[var(--color-muted)] uppercase tracking-[0.12em] font-bold">
        Last refreshed: {generatedAt} &middot; {items.length} items
      </p>
    )}
  </section>

  {featuredItems.length > 0 && (
    <section class="max-w-4xl mx-auto px-5 pt-2 pb-2">
      <h2 class="font-sans font-extrabold uppercase tracking-[0.18em] text-xs text-[var(--color-orange-deep)] mb-3">
        ★ Featured
      </h2>
      <div class="grid gap-5">
        {featuredItems.map((item: any) => (
          <article class="poster-card p-5 md:p-6 border-[3px] border-[var(--color-orange)] shadow-[0_6px_0_0_var(--color-orange-deep),0_14px_30px_-10px_rgba(20,38,64,0.25)]">
            <p class="text-[10px] font-extrabold uppercase tracking-[0.18em] text-[var(--color-orange-deep)]">
              {fmtDate(item.publishedAt)} &middot; <span class="text-[var(--color-muted)]">{item.source}</span>
            </p>
            <h3 class="mt-2 display text-2xl md:text-3xl leading-tight text-[var(--color-blue)]">
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="no-underline hover:text-[var(--color-orange-deep)]">
                {item.title}
              </a>
            </h3>
            {item.summary && (
              <p class="mt-3 text-[var(--color-ink-soft)]">{item.summary}</p>
            )}
            {item.blurb && (
              <p class="mt-3 text-[var(--color-ink)] italic border-l-4 border-[var(--color-orange)] pl-3">
                {item.blurb}
              </p>
            )}
            {item.primarySourceUrl && (
              <p class="mt-3 text-xs text-[var(--color-muted)]">
                Primary source: <a href={item.primarySourceUrl} target="_blank" rel="noopener noreferrer">{item.primarySourceLabel ?? item.primarySourceUrl}</a>
              </p>
            )}
            <ul class="mt-3 flex flex-wrap gap-2">
              {(item.tags ?? []).map((t: string) => (
                <li class={`text-[10px] font-extrabold uppercase tracking-[0.12em] px-2 py-0.5 rounded-full bg-[var(--color-blue)]/10 text-[var(--color-blue)]`}>
                  {TAG_LABEL[t] ?? t}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-5 pt-8 pb-2">
    <h2 class="font-sans font-extrabold uppercase tracking-[0.18em] text-xs text-[var(--color-orange-deep)]">
      All stories
    </h2>
    <div class="mt-3 flex flex-wrap gap-2 items-center" id="feed-filters">
      <span class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-[var(--color-muted)] mr-1">Filter:</span>
      <button
        type="button"
        class="feed-tag-btn font-sans font-extrabold uppercase tracking-[0.12em] text-[11px] px-3 py-1.5 rounded-full border-2 transition-all bg-[var(--color-blue)] text-white border-[var(--color-blue-deep)]"
        data-tag="all"
        aria-pressed="true"
      >All</button>
      {allTags.map((t) => (
        <button
          type="button"
          class="feed-tag-btn font-sans font-extrabold uppercase tracking-[0.12em] text-[11px] px-3 py-1.5 rounded-full border-2 border-[var(--color-blue)]/40 text-[var(--color-blue)] hover:bg-[var(--color-blue)] hover:text-white transition-all"
          data-tag={t}
          aria-pressed="false"
        >{TAG_LABEL[t]}</button>
      ))}
      <span id="feed-count" class="ml-auto text-xs font-extrabold uppercase tracking-[0.15em] text-[var(--color-muted)]">{items.length} items</span>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-5 pb-24">
    {items.length === 0 ? (
      <p class="mt-8 text-[var(--color-muted)] italic">Nothing aggregated yet — run <code>npm run aggregate</code>.</p>
    ) : (
      <ul class="mt-4 grid gap-3" id="feed-list">
        {items.map((item: any) => (
          <li
            class="feed-item poster-card p-4 md:p-5"
            data-tags={(item.tags ?? []).join(',')}
          >
            <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-[var(--color-orange-deep)]">
              {fmtDate(item.publishedAt)} &middot; <span class="text-[var(--color-muted)]">{item.source}</span>
            </p>
            <h3 class="mt-1.5 font-extrabold text-base md:text-lg leading-snug text-[var(--color-blue)]">
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="no-underline hover:text-[var(--color-orange-deep)]">
                {item.title}
              </a>
            </h3>
            {item.summary && item.summary.length > 30 && (
              <p class="mt-2 text-sm text-[var(--color-ink-soft)] line-clamp-2">{item.summary}</p>
            )}
            <ul class="mt-2 flex flex-wrap gap-1.5">
              {(item.tags ?? []).map((t: string) => (
                <li class="text-[9px] font-extrabold uppercase tracking-[0.12em] px-2 py-0.5 rounded-full bg-[var(--color-blue)]/10 text-[var(--color-blue)]">
                  {TAG_LABEL[t] ?? t}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    )}

    <p id="feed-empty" class="hidden mt-8 text-center text-[var(--color-muted)] italic">No stories match this filter.</p>
  </section>

  <script is:inline>
    (() => {
      const init = () => {
        const buttons = Array.from(document.querySelectorAll('.feed-tag-btn'));
        const items = Array.from(document.querySelectorAll('.feed-item'));
        const empty = document.getElementById('feed-empty');
        const count = document.getElementById('feed-count');
        if (!buttons.length || !items.length) return;

        const ACTIVE = 'bg-[var(--color-blue)] text-white border-[var(--color-blue-deep)]';
        const INACTIVE = 'border-[var(--color-blue)]/40 text-[var(--color-blue)]';

        const apply = (tag) => {
          let shown = 0;
          items.forEach((li) => {
            const tags = (li.dataset.tags || '').split(',').filter(Boolean);
            const visible = tag === 'all' || tags.includes(tag);
            li.hidden = !visible;
            if (visible) shown++;
          });
          empty.classList.toggle('hidden', shown > 0);
          count.textContent = (tag === 'all' ? shown : shown + ' / ' + items.length) + ' item' + (shown === 1 ? '' : 's');

          buttons.forEach((b) => {
            const active = b.dataset.tag === tag;
            b.setAttribute('aria-pressed', active ? 'true' : 'false');
            ACTIVE.split(' ').forEach((c) => b.classList.toggle(c, active));
            INACTIVE.split(' ').forEach((c) => b.classList.toggle(c, !active));
          });
        };

        buttons.forEach((b) => {
          b.addEventListener('click', () => apply(b.dataset.tag));
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</Layout>
