---
import Layout from '../../layouts/Layout.astro';
import { clockIncident } from '../../config/clock-incident';

const incidentDate = new Date(clockIncident.date);
const incidentDateDisplay = incidentDate.toLocaleString('en-US', {
  weekday: 'short',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  timeZoneName: 'short',
});
---
<Layout title="The Clock — dudewheresmylikeness.com">
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-4">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">The Clock</p>
    <h1 class="mt-3 font-serif text-4xl md:text-5xl tracking-tight">
      How long has it been?
    </h1>
    <p class="mt-4 text-[var(--color-muted)] max-w-2xl">
      Time elapsed since the last flagged unauthorized AI likeness incident. The joke
      is that it never gets to reset for long.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-6">
    {/* TODO: Replace this placeholder SVG with the final illustrated hero —
        early-2000s slacker vibe, hand-drawn or slightly pixelated, pastiche of
        Dude, Where's My Car. Save the final asset to /public/images/clock-hero.svg
        (or .png) and swap the <svg> below for an <img> pointing at it. Do NOT
        use Ashton Kutcher's actual photo. */}
    <div class="border border-[var(--color-rule)] bg-white aspect-[5/2] flex items-center justify-center relative overflow-hidden">
      <svg viewBox="0 0 500 200" class="w-full h-full" aria-hidden="true">
        <defs>
          <pattern id="dots" x="0" y="0" width="8" height="8" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="0.8" fill="#c9a96e" opacity="0.35" />
          </pattern>
        </defs>
        <rect width="500" height="200" fill="url(#dots)" />
        <text x="250" y="100" text-anchor="middle" font-family="Charter, serif" font-size="22" fill="#6b6658" font-style="italic">
          dude — where's my likeness?
        </text>
        <text x="250" y="130" text-anchor="middle" font-family="ui-monospace, monospace" font-size="11" fill="#a0231e" letter-spacing="2">
          [ILLUSTRATED HERO — PLACEHOLDER]
        </text>
      </svg>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-10">
    <p class="text-sm text-[var(--color-muted)] uppercase tracking-[0.2em]">It has been</p>
    <div
      id="clock-readout"
      class="mt-3 font-serif text-4xl md:text-6xl tracking-tight tabular-nums"
      data-incident-iso={clockIncident.date}
      aria-live="polite"
    >
      <span id="clock-days">—</span><span class="text-[var(--color-muted)] text-xl md:text-2xl ml-2 font-sans">days</span>
      <span id="clock-hours" class="ml-4">—</span><span class="text-[var(--color-muted)] text-xl md:text-2xl ml-2 font-sans">hours</span>
      <span id="clock-minutes" class="ml-4">—</span><span class="text-[var(--color-muted)] text-xl md:text-2xl ml-2 font-sans">min</span>
      <span id="clock-seconds" class="ml-4">—</span><span class="text-[var(--color-muted)] text-xl md:text-2xl ml-2 font-sans">sec</span>
    </div>
    <p class="mt-3 text-sm text-[var(--color-muted)]">
      since the last flagged unauthorized AI likeness incident.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-24">
    <div class="border-t border-[var(--color-rule)] pt-6">
      <p class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)]">Reference incident</p>
      <h2 class="mt-2 font-serif text-2xl leading-snug">{clockIncident.headline}</h2>
      <p class="mt-3 text-[var(--color-muted)]">{clockIncident.description}</p>
      <p class="mt-3 text-sm">
        <a href={clockIncident.sourceUrl} target="_blank" rel="noopener noreferrer">
          {clockIncident.sourceName}
        </a>
        <span class="text-[var(--color-muted)]"> — {incidentDateDisplay}</span>
      </p>
    </div>
  </section>

  <script is:inline>
    (() => {
      const el = document.getElementById('clock-readout');
      if (!el) return;
      const iso = el.getAttribute('data-incident-iso');
      if (!iso) return;
      const incidentMs = new Date(iso).getTime();
      const $days = document.getElementById('clock-days');
      const $hours = document.getElementById('clock-hours');
      const $minutes = document.getElementById('clock-minutes');
      const $seconds = document.getElementById('clock-seconds');
      const pad = (n) => String(n).padStart(2, '0');

      const tick = () => {
        const now = Date.now();
        let diff = Math.max(0, Math.floor((now - incidentMs) / 1000));
        const days = Math.floor(diff / 86400); diff -= days * 86400;
        const hours = Math.floor(diff / 3600); diff -= hours * 3600;
        const minutes = Math.floor(diff / 60); diff -= minutes * 60;
        const seconds = diff;
        $days.textContent = String(days);
        $hours.textContent = pad(hours);
        $minutes.textContent = pad(minutes);
        $seconds.textContent = pad(seconds);
      };
      tick();
      setInterval(tick, 1000);
    })();
  </script>
</Layout>
