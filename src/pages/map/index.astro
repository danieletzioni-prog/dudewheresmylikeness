---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { STATE_GRID, GRID_COLS, GRID_ROWS } from '../../data/state-grid';

const states = await getCollection('states');
const byAbbr = new Map(states.map((s) => [s.data.abbr, s.data]));

const TILE = 56;
const GAP = 4;
const PAD = 8;
const width = GRID_COLS * (TILE + GAP) - GAP + PAD * 2;
const height = GRID_ROWS * (TILE + GAP) - GAP + PAD * 2;

const strengthClass: Record<string, string> = {
  none: 'fill-[var(--color-strength-none)]',
  weak: 'fill-[var(--color-strength-weak)]',
  moderate: 'fill-[var(--color-strength-moderate)]',
  strong: 'fill-[var(--color-strength-strong)]',
  explicit: 'fill-[var(--color-strength-explicit)]',
};

const legend: Array<{ key: keyof typeof strengthClass; label: string }> = [
  { key: 'none', label: 'No documented protection' },
  { key: 'weak', label: 'Weak / common law only' },
  { key: 'moderate', label: 'Moderate statute' },
  { key: 'strong', label: 'Strong statute, limited AI coverage' },
  { key: 'explicit', label: 'Explicit AI / digital replica coverage' },
];

// Build a serializable map for the client-side side panel.
const stateDataForClient = Object.fromEntries(
  states.map((s) => [s.data.abbr, s.data]),
);
---
<Layout title="The Map — dudewheresmylikeness.com">
  <section class="max-w-5xl mx-auto px-6 pt-12 pb-6">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">The Map</p>
    <h1 class="mt-3 font-serif text-4xl md:text-5xl tracking-tight">
      Where does your likeness live?
    </h1>
    <p class="mt-4 text-[var(--color-muted)] max-w-2xl">
      State-by-state posture on right of publicity, post-mortem protection, and
      explicit AI digital-replica coverage. Click any state to see what's on the books.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-6">
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-[var(--color-muted)]">
      {legend.map((item) => (
        <li class="flex items-center gap-2">
          <span class={`inline-block w-3 h-3 ${strengthClass[item.key]} border border-[var(--color-rule)]`}></span>
          {item.label}
        </li>
      ))}
    </ul>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-24 grid gap-8 lg:grid-cols-[1fr_22rem]">
    <div class="overflow-x-auto">
      <svg
        id="us-tile-map"
        viewBox={`0 0 ${width} ${height}`}
        width="100%"
        class="max-w-full h-auto select-none"
        role="img"
        aria-label="Tile-grid map of the United States"
      >
        {STATE_GRID.map((cell) => {
          const data = byAbbr.get(cell.abbr);
          const x = PAD + cell.col * (TILE + GAP);
          const y = PAD + cell.row * (TILE + GAP);
          const strength = data?.strength ?? 'none';
          return (
            <g
              class="state-tile cursor-pointer"
              data-abbr={cell.abbr}
              transform={`translate(${x}, ${y})`}
              tabindex="0"
              role="button"
              aria-label={data?.name ?? cell.abbr}
            >
              <rect
                width={TILE}
                height={TILE}
                rx="2"
                class={`${strengthClass[strength]} stroke-[var(--color-rule)] transition-[filter]`}
                stroke-width="1"
              />
              <text
                x={TILE / 2}
                y={TILE / 2 + 5}
                text-anchor="middle"
                class="pointer-events-none text-[14px] font-semibold"
                fill={strength === 'explicit' || strength === 'strong' ? '#fafaf5' : '#121212'}
              >
                {cell.abbr}
              </text>
            </g>
          );
        })}
      </svg>
    </div>

    <aside
      id="state-panel"
      class="border border-[var(--color-rule)] bg-white p-6 self-start lg:sticky lg:top-6 text-sm"
      aria-live="polite"
    >
      <div id="state-panel-empty">
        <p class="text-[var(--color-muted)] italic">
          Click any state to see its posture on AI likeness rights.
        </p>
      </div>
      <div id="state-panel-content" hidden>
        <p class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)]" data-field="abbr"></p>
        <h2 class="mt-2 font-serif text-2xl" data-field="name"></h2>
        <p class="mt-2 text-[var(--color-muted)] italic" data-field="summary"></p>

        <dl class="mt-5 grid gap-3">
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]">Right of publicity</dt>
            <dd class="mt-0.5" data-field="rightOfPublicity"></dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]">Post-mortem</dt>
            <dd class="mt-0.5" data-field="postMortem"></dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]">AI / digital replica coverage</dt>
            <dd class="mt-0.5" data-field="aiCoverage"></dd>
          </div>
        </dl>

        <div class="mt-5" id="panel-legislation-wrap" hidden>
          <p class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]">Key legislation</p>
          <ul class="mt-1 list-disc pl-5" id="panel-legislation"></ul>
        </div>

        <div class="mt-5" id="panel-cases-wrap" hidden>
          <p class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]">Notable cases</p>
          <ul class="mt-1 list-disc pl-5" id="panel-cases"></ul>
        </div>

        <p class="mt-6 text-xs text-[var(--color-muted)]">
          Last updated <span data-field="lastUpdated"></span>
        </p>
      </div>
    </aside>
  </section>

  <script id="state-data" type="application/json" set:html={JSON.stringify(stateDataForClient)} is:inline />

  <script is:inline>
    (() => {
      const raw = document.getElementById('state-data')?.textContent ?? '{}';
      const DATA = JSON.parse(raw);
      const panel = document.getElementById('state-panel');
      const empty = document.getElementById('state-panel-empty');
      const content = document.getElementById('state-panel-content');

      const setText = (field, value) => {
        panel.querySelectorAll(`[data-field="${field}"]`).forEach((el) => {
          el.textContent = value ?? '';
        });
      };

      const renderLinks = (listId, wrapId, items) => {
        const ul = document.getElementById(listId);
        const wrap = document.getElementById(wrapId);
        ul.innerHTML = '';
        if (!items || items.length === 0) {
          wrap.hidden = true;
          return;
        }
        wrap.hidden = false;
        items.forEach((item) => {
          const li = document.createElement('li');
          if (item.url) {
            const a = document.createElement('a');
            a.href = item.url;
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
            a.textContent = item.title;
            li.appendChild(a);
          } else {
            li.textContent = item.title;
          }
          if (item.note) {
            const note = document.createElement('span');
            note.textContent = ` — ${item.note}`;
            note.className = 'text-[var(--color-muted)]';
            li.appendChild(note);
          }
          ul.appendChild(li);
        });
      };

      const select = (abbr) => {
        const d = DATA[abbr];
        if (!d) return;
        empty.hidden = true;
        content.hidden = false;
        setText('abbr', d.abbr);
        setText('name', d.name);
        setText('summary', d.summary || '');
        setText('rightOfPublicity', d.rightOfPublicity);
        setText('postMortem', d.postMortem);
        setText('aiCoverage', d.aiCoverage);
        setText('lastUpdated', d.lastUpdated);
        renderLinks('panel-legislation', 'panel-legislation-wrap', d.keyLegislation);
        renderLinks('panel-cases', 'panel-cases-wrap', d.notableCases);

        document.querySelectorAll('.state-tile rect').forEach((r) => {
          r.style.filter = '';
          r.setAttribute('stroke-width', '1');
        });
        const active = document.querySelector(`.state-tile[data-abbr="${abbr}"] rect`);
        if (active) {
          active.style.filter = 'brightness(1.1)';
          active.setAttribute('stroke-width', '2.5');
          active.setAttribute('stroke', '#121212');
        }
      };

      document.querySelectorAll('.state-tile').forEach((tile) => {
        const abbr = tile.getAttribute('data-abbr');
        tile.addEventListener('click', () => select(abbr));
        tile.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            select(abbr);
          }
        });
        tile.addEventListener('mouseenter', () => {
          const rect = tile.querySelector('rect');
          if (rect) rect.style.filter = 'brightness(1.08)';
        });
        tile.addEventListener('mouseleave', () => {
          const rect = tile.querySelector('rect');
          if (!rect) return;
          if (rect.getAttribute('stroke-width') !== '2.5') rect.style.filter = '';
        });
      });

      // Open California by default so the panel isn't empty on first paint.
      if (DATA.CA) select('CA');
    })();
  </script>
</Layout>
