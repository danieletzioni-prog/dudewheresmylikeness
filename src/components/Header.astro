---
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};

const links = [
  { href: '/', label: 'Home' },
  { href: '/map', label: 'Map' },
  { href: '/clock', label: 'Clock' },
  { href: '/feed', label: 'Feed' },
];
---
<header class="border-b border-[var(--color-rule)]">
  <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between gap-6">
    <a href="/" class="no-underline group">
      <span class="font-serif text-xl font-semibold tracking-tight">
        dudewheresmylikeness<span class="text-[var(--color-muted)]">.com</span>
      </span>
    </a>
    <nav>
      <ul class="flex items-center gap-5 text-sm">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'no-underline uppercase tracking-wider text-xs',
                isActive(link.href)
                  ? 'text-[var(--color-ink)] font-semibold'
                  : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
